# Copy to .env for local dev. On Railway these are set in the dashboard.

# Port the server listens on (Railway sets this automatically).
PORT=3000

# Postgres connection string. If unset, the app uses an in-memory store
# (fine for local testing; data is lost on restart — DO set this in production).
# On Railway: add a Postgres plugin and reference its DATABASE_URL.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Set to "true" to force SSL on the Postgres connection (some hosts require it).
# PGSSL=true

# Shared secret for the cron service to trigger scheduled jobs (POST /api/cron/:job).
# Set the SAME value on both the web service and the cron service.
# CRON_SECRET=change-me

# On the web service: set to "off" once the cron service owns scheduling, to
# disable the in-process hourly backstop. Leave unset to keep the backstop.
# SELF_SYNC=off

# --- cron service only ---
# WEB_URL=https://your-web-service.up.railway.app
# CRON_JOBS=sync

# --- email magic-link login (recommended) ---
# Railway doesn't send email; use a provider. Resend is simplest:
#   1. sign up at resend.com, verify the wcpool.app domain (add its DNS records)
#   2. create an API key
# EMAIL_TRANSPORT=resend                 # or "console" to log instead of send (dev)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=World Cup Pool <hello@wcpool.app>
# APP_URL=https://wcpool.app             # base for the magic links

# --- texting (Twilio) — optional/legacy ---
# Public base URL used in SMS links (so they point at your domain).
# APP_URL=https://wcpool.app
# Auth: either Account SID + Auth Token, OR API Key SID + its Secret.
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_API_KEY_SID=SKxxxxxxxx        # only if using an API Key (the Secret goes in TWILIO_AUTH_TOKEN)
# TWILIO_AUTH_TOKEN=your-auth-token-or-api-key-secret
# Sender: a Twilio phone number (+1...) OR a Messaging Service SID (MG...).
# TWILIO_FROM=+15551234567
# TWILIO_DEFAULT_CC=1                   # country code assumed for local-format numbers
# SMS_TRANSPORT=twilio                  # set to "console" to log texts instead of sending (dev)
